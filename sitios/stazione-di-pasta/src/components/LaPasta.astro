---
// La pasta (Productos) — Stazione di Pasta
// Carrusel horizontal con scroll-snap + cierre narrativo animado + CTA

const slides = [
  { src: '/img/productos/p1.jpg', alt: 'Variedad de pastas Stazione' },
  { src: '/img/productos/p3.jpg', alt: 'Sorrentinos artesanales' },
  { src: '/img/productos/p4.jpg', alt: 'Pastas frescas en preparación' },
  { src: '/img/productos/p5.jpg', alt: 'Pasta lista para servir' },
  { src: '/img/productos/p6.jpg', alt: 'Platos especiales del día' },
  { src: '/img/productos/p7.jpg', alt: 'Selección de pastas rellenas' },
  { src: '/img/productos/p8.jpg', alt: 'Producto Stazione' },
];
---

<section id="productos" class="relative py-24 md:py-36 bg-sdp-negro overflow-hidden">
  <!-- Espigas decorativas SVG -->
  <svg class="absolute top-16 right-4 md:right-12 w-16 md:w-24 text-sdp-dorado/30 pointer-events-none" viewBox="0 0 40 60" fill="none" aria-hidden="true">
    <path d="M 20 4 L 20 56" stroke="currentColor" stroke-width="1.2" />
    <ellipse cx="14" cy="14" rx="4" ry="2" stroke="currentColor" stroke-width="1" transform="rotate(-30 14 14)" />
    <ellipse cx="26" cy="14" rx="4" ry="2" stroke="currentColor" stroke-width="1" transform="rotate(30 26 14)" />
    <ellipse cx="14" cy="26" rx="4" ry="2" stroke="currentColor" stroke-width="1" transform="rotate(-30 14 26)" />
    <ellipse cx="26" cy="26" rx="4" ry="2" stroke="currentColor" stroke-width="1" transform="rotate(30 26 26)" />
    <ellipse cx="14" cy="38" rx="4" ry="2" stroke="currentColor" stroke-width="1" transform="rotate(-30 14 38)" />
    <ellipse cx="26" cy="38" rx="4" ry="2" stroke="currentColor" stroke-width="1" transform="rotate(30 26 38)" />
  </svg>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto reveal">
      <p class="font-body text-xs uppercase tracking-[0.35em] text-sdp-dorado mb-6">
        02 — La pasta
      </p>
      <h2 class="font-display text-3xl md:text-5xl lg:text-6xl text-sdp-mediterraneo leading-[1.15]">
        Un raviol guarda <em class="italic text-sdp-carmin font-normal">un secreto</em> adentro.
      </h2>
      <p class="mt-8 font-display italic text-lg md:text-xl text-sdp-mediterraneo/75 leading-relaxed max-w-2xl mx-auto">
        Quizás sea ricota. Quizás sea la receta que nadie en tu familia se atrevió a cambiar.
      </p>
    </div>

    <!-- Carrusel -->
    <div class="mt-16 md:mt-20 relative reveal" data-carrusel-wrap>
      <!-- Botón anterior -->
      <button
        type="button"
        data-carrusel-prev
        aria-label="Imagen anterior"
        class="hidden md:flex absolute left-0 top-1/2 -translate-y-1/2 z-10 -translate-x-3 lg:-translate-x-5 items-center justify-center h-12 w-12 rounded-full bg-sdp-mediterraneo/90 hover:bg-sdp-mediterraneo text-sdp-negro shadow-2xl transition-all hover:scale-105 disabled:opacity-30 disabled:cursor-not-allowed"
      >
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="13 16 7 10 13 4" />
        </svg>
      </button>

      <!-- Track -->
      <div
        data-carrusel-track
        class="flex gap-3 md:gap-5 overflow-x-auto snap-x snap-mandatory scroll-smooth scrollbar-hide pb-4 -mx-4 px-4 sm:mx-0 sm:px-0"
      >
        {slides.map((slide) => (
          <div class="snap-center flex-shrink-0 w-[80%] sm:w-[55%] md:w-[42%] lg:w-[32%] group relative overflow-hidden rounded-sm">
            <div class="aspect-[3/4]">
              <img
                src={slide.src}
                alt={slide.alt}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-105"
              />
            </div>
            <!-- Sombra inferior sutil -->
            <div class="absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-sdp-negro/40 to-transparent pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </div>
        ))}
      </div>

      <!-- Botón siguiente -->
      <button
        type="button"
        data-carrusel-next
        aria-label="Imagen siguiente"
        class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 z-10 translate-x-3 lg:translate-x-5 items-center justify-center h-12 w-12 rounded-full bg-sdp-mediterraneo/90 hover:bg-sdp-mediterraneo text-sdp-negro shadow-2xl transition-all hover:scale-105 disabled:opacity-30 disabled:cursor-not-allowed"
      >
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="7 4 13 10 7 16" />
        </svg>
      </button>

      <!-- Indicadores (dots) -->
      <div class="mt-6 flex justify-center gap-2" data-carrusel-dots>
        {slides.map((_, i) => (
          <button
            type="button"
            data-carrusel-dot={i}
            aria-label={`Ir a imagen ${i + 1}`}
            class="h-1.5 w-6 md:w-8 rounded-full bg-sdp-mediterraneo/25 hover:bg-sdp-mediterraneo/60 transition-all"
          ></button>
        ))}
      </div>

      <!-- Hint mobile -->
      <p class="mt-3 md:hidden text-center font-body text-xs text-sdp-mediterraneo/40 italic">
        Deslizá para ver más →
      </p>
    </div>

    <!-- Cierre narrativo con animación -->
    <div class="mt-24 md:mt-32 max-w-3xl mx-auto text-center proxima-parada-reveal">
      <div class="flex justify-center mb-10">
        <span class="inline-block w-px bg-sdp-dorado proxima-line"></span>
      </div>

      <h3 class="font-display text-3xl md:text-5xl lg:text-6xl text-sdp-mediterraneo leading-[1.15] proxima-title">
        Tu próxima parada:<br />
        <em class="italic text-sdp-carmin font-normal whitespace-nowrap">pasta fresca</em>.
      </h3>

      <p class="mt-8 font-display italic text-lg md:text-xl text-sdp-mediterraneo/75 leading-relaxed proxima-sub">
        Pasá por Stazione Di Pasta y descubrí nuestras pastas frescas, platos listos y especialidades del día.
      </p>
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center reveal">
      <a
        href="https://www.pxw.com.ar/StazioneDiPasta"
        target="_blank"
        rel="noopener"
        class="group inline-flex items-center gap-3 bg-sdp-carmin hover:bg-sdp-carmin-oscuro text-sdp-mediterraneo px-8 py-4 font-display text-base md:text-lg transition-all duration-500 shadow-xl shadow-sdp-carmin/30 hover:-translate-y-0.5"
      >
        <span>Hacé tu pedido</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* Ocultar scrollbar manteniendo scroll funcional */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Dot activo */
  [data-carrusel-dot].is-active {
    background-color: #DC3036 !important;
    width: 32px;
  }
  @media (min-width: 768px) {
    [data-carrusel-dot].is-active {
      width: 48px;
    }
  }

  /* Animación cierre "Tu próxima parada" */
  .proxima-line {
    height: 0;
    transition: height 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .proxima-title,
  .proxima-sub {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1.1s ease, transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .proxima-sub {
    transition-delay: 0.25s;
  }

  .proxima-parada-reveal.is-visible .proxima-line {
    height: 48px;
  }
  .proxima-parada-reveal.is-visible .proxima-title,
  .proxima-parada-reveal.is-visible .proxima-sub {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // === Carrusel ===
  document.querySelectorAll('[data-carrusel-wrap]').forEach((wrap) => {
    const track = wrap.querySelector('[data-carrusel-track]');
    const prevBtn = wrap.querySelector('[data-carrusel-prev]');
    const nextBtn = wrap.querySelector('[data-carrusel-next]');
    const dots = Array.from(wrap.querySelectorAll('[data-carrusel-dot]'));
    if (!track) return;

    const getSlideWidth = () => {
      const first = track.firstElementChild;
      if (!first) return 0;
      const gap = parseFloat(getComputedStyle(track).columnGap || '0');
      return first.offsetWidth + gap;
    };

    const scrollByDir = (dir) => {
      track.scrollBy({ left: getSlideWidth() * dir, behavior: 'smooth' });
    };

    if (prevBtn) prevBtn.addEventListener('click', () => scrollByDir(-1));
    if (nextBtn) nextBtn.addEventListener('click', () => scrollByDir(1));

    // Click en dots
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        const slide = track.children[i];
        if (slide) slide.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      });
    });

    // Update dot activo según scroll
    const updateActive = () => {
      const slideW = getSlideWidth();
      if (!slideW) return;
      const idx = Math.round(track.scrollLeft / slideW);
      dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
      if (prevBtn) prevBtn.disabled = track.scrollLeft <= 4;
      if (nextBtn) nextBtn.disabled = track.scrollLeft >= track.scrollWidth - track.clientWidth - 4;
    };

    track.addEventListener('scroll', updateActive, { passive: true });
    window.addEventListener('resize', updateActive);
    updateActive();
  });

  // === Reveal cierre "Tu próxima parada" ===
  const proxObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          proxObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );
  document.querySelectorAll('.proxima-parada-reveal').forEach((el) => proxObserver.observe(el));
</script>
