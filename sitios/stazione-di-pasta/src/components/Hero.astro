---
// Hero — Stazione di Pasta
// Frase del manifiesto + video de fondo orgánico
---

<section
  id="hero"
  class="relative min-h-screen flex items-end overflow-hidden bg-sdp-negro"
>
  <!-- Video de fondo -->
  <div class="absolute inset-0">
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      poster="/img/fabrica/f1.jpg"
      aria-hidden="true"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>

    <!-- Overlay gradient para legibilidad -->
    <div class="absolute inset-0 bg-gradient-to-b from-sdp-negro/40 via-sdp-negro/55 to-sdp-negro/90"></div>

    <!-- Viñeta sutil -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, transparent 40%, rgba(45,45,45,0.5) 100%);"></div>
  </div>

  <!-- Línea decorativa carmín superior -->
  <div class="absolute top-0 inset-x-0 h-[3px] bg-sdp-carmin opacity-80 z-10"></div>

  <!-- Espigas decorativas izquierda -->
  <div class="hidden md:block absolute left-6 top-1/2 -translate-y-1/2 opacity-30 z-10" aria-hidden="true">
    <svg width="40" height="160" viewBox="0 0 40 160" fill="none">
      <path d="M 20 0 V 160" stroke="#B98D17" stroke-width="1.5" />
      <ellipse cx="14" cy="30" rx="6" ry="3" stroke="#B98D17" stroke-width="1" transform="rotate(-30 14 30)" />
      <ellipse cx="26" cy="40" rx="6" ry="3" stroke="#B98D17" stroke-width="1" transform="rotate(30 26 40)" />
      <ellipse cx="14" cy="55" rx="6" ry="3" stroke="#B98D17" stroke-width="1" transform="rotate(-30 14 55)" />
      <ellipse cx="26" cy="65" rx="6" ry="3" stroke="#B98D17" stroke-width="1" transform="rotate(30 26 65)" />
      <ellipse cx="14" cy="80" rx="6" ry="3" stroke="#B98D17" stroke-width="1" transform="rotate(-30 14 80)" />
      <ellipse cx="26" cy="90" rx="6" ry="3" stroke="#B98D17" stroke-width="1" transform="rotate(30 26 90)" />
    </svg>
  </div>

  <!-- Contenido principal -->
  <div class="relative z-20 w-full mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-20 md:pb-28 pt-32">
    <div class="max-w-3xl">
      <!-- Eyebrow -->
      <p class="font-body text-xs uppercase tracking-[0.3em] text-sdp-dorado opacity-0 animate-fade-in" style="animation-delay: 0.4s;">
        Villa Ballester — Argentina
      </p>

      <!-- Headline -->
      <h1 class="mt-7 font-display text-sdp-mediterraneo leading-[1.05] tracking-tight">
        <span class="block text-4xl sm:text-5xl md:text-6xl lg:text-7xl opacity-0 animate-reveal" style="animation-delay: 0.6s;">
          Una estación
        </span>
        <span class="block text-4xl sm:text-5xl md:text-6xl lg:text-7xl mt-1 opacity-0 animate-reveal" style="animation-delay: 1.0s;">
          para los que aman
        </span>
        <span class="block italic font-light text-4xl sm:text-5xl md:text-6xl lg:text-7xl mt-1 text-sdp-carmin opacity-0 animate-reveal" style="animation-delay: 1.4s;">
          la pasta.
        </span>
      </h1>

      <!-- Sub-frase -->
      <div class="mt-10 max-w-xl opacity-0 animate-fade-up-slow" style="animation-delay: 1.9s;">
        <p class="font-display italic text-lg md:text-xl text-sdp-mediterraneo/85 leading-relaxed">
          Pastas frescas para los que todavía creen<br class="hidden md:block" />
          que comer bien puede cambiar el día.
        </p>
      </div>

      <!-- CTAs -->
      <div class="mt-12 flex flex-wrap items-center gap-6 opacity-0 animate-fade-up-slow" style="animation-delay: 2.3s;">
        <a
          href="https://www.pxw.com.ar/StazioneDiPasta"
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-3 bg-sdp-carmin hover:bg-sdp-carmin-oscuro text-sdp-mediterraneo px-7 py-4 font-display text-base md:text-lg transition-all duration-500 shadow-xl shadow-sdp-carmin/30 hover:-translate-y-0.5"
        >
          <span>Hacé tu pedido</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
          </svg>
        </a>

        <a
          href="#filosofia"
          class="inline-flex items-center gap-2 font-display italic text-sdp-mediterraneo/90 hover:text-sdp-dorado transition-colors group text-base"
        >
          <span class="underline-offset-4 decoration-sdp-dorado/40 group-hover:underline">Conocé nuestra filosofía</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 opacity-0 animate-fade-in" style="animation-delay: 3s;">
    <div class="flex flex-col items-center gap-3 text-sdp-mediterraneo/40">
      <span class="font-display italic text-xs">descendé</span>
      <span class="block h-10 w-px bg-sdp-mediterraneo/30">
        <span class="block h-1/2 w-full bg-sdp-dorado animate-pulse"></span>
      </span>
    </div>
  </div>
</section>
