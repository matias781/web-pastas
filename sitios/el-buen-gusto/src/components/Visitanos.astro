---
// Visitanos — El Buen Gusto
// Mapa + datos de contacto
---

<section id="visitanos" class="relative py-20 md:py-28 bg-white overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto reveal">
      <span class="inline-block font-display text-xs uppercase tracking-[0.25em] text-ebg-naranja-oscuro font-semibold mb-4">
        Encontranos
      </span>
      <h2 class="font-display font-bold text-3xl md:text-5xl text-ebg-negro leading-tight">
        Te esperamos en <span class="text-ebg-naranja italic">Villa Ballester</span>.
      </h2>
    </div>

    <!-- Grid Maps + Info -->
    <div class="mt-14 grid grid-cols-1 lg:grid-cols-5 gap-8 reveal">
      <!-- Mapa -->
      <div class="lg:col-span-3 aspect-[4/3] lg:aspect-auto rounded-3xl overflow-hidden shadow-2xl shadow-ebg-negro/20 border-4 border-ebg-crema">
        <iframe
          src="https://www.google.com/maps?q=Pueyrredon%202631%2C%20Villa%20Ballester%2C%20Buenos%20Aires&output=embed"
          class="w-full h-full min-h-[400px]"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación El Buen Gusto Pastas"
        ></iframe>
      </div>

      <!-- Datos -->
      <div class="lg:col-span-2 flex flex-col justify-between gap-8">
        <!-- Card de dirección -->
        <div class="bg-ebg-negro text-ebg-crema rounded-3xl p-8 shadow-xl">
          <div class="flex items-start gap-3">
            <svg class="h-7 w-7 text-ebg-naranja flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <div>
              <p class="font-display text-xs uppercase tracking-widest text-ebg-naranja mb-1">Dirección</p>
              <p class="font-display font-bold text-xl leading-tight">Pueyrredón 2631</p>
              <p class="font-body text-sm text-ebg-crema/80 mt-1">Villa Ballester, Buenos Aires</p>
            </div>
          </div>

          <div class="mt-7 pt-6 border-t border-ebg-crema/15 flex items-start gap-3">
            <svg class="h-7 w-7 text-ebg-naranja flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            <div>
              <p class="font-display text-xs uppercase tracking-widest text-ebg-naranja mb-1">Horarios</p>
              <p class="font-body text-sm leading-relaxed">
                Martes a sábados · 8:30 a 20:30<br/>
                Domingo · 8:30 a 13:30
              </p>
            </div>
          </div>

          <div class="mt-7 pt-6 border-t border-ebg-crema/15 flex items-start gap-3">
            <svg class="h-7 w-7 text-ebg-naranja flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/>
            </svg>
            <div>
              <p class="font-display text-xs uppercase tracking-widest text-ebg-naranja mb-1">WhatsApp</p>
              <a href="https://wa.me/5491132642454" target="_blank" rel="noopener" class="font-body text-sm leading-relaxed hover:text-ebg-naranja transition-colors">
                +54 9 11 3264-2454
              </a>
            </div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col gap-3">
          <a
            href="https://maps.app.goo.gl/GdcfP1J5vrxn1xos7"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-ebg-naranja hover:bg-ebg-naranja-oscuro text-ebg-crema px-6 py-3.5 font-display font-bold text-sm transition-all duration-300 shadow-lg shadow-ebg-naranja/30 hover:-translate-y-0.5"
          >
            Cómo llegar
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" /></svg>
          </a>
          <a
            href="https://www.instagram.com/elbuengustopastasfrescas/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-ebg-negro/10 hover:border-ebg-naranja hover:text-ebg-naranja text-ebg-negro px-6 py-3.5 font-display font-bold text-sm transition-colors"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            @elbuengustopastasfrescas
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
