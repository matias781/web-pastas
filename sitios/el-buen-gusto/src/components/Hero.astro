---
// Hero — El Buen Gusto Pastas
// Slogan: Tradición de barrio, mirada de futuro
---

<section
  id="hero"
  class="relative min-h-screen flex items-center overflow-hidden bg-ebg-crema pt-24 pb-16"
>
  <!-- Patrón decorativo de pastas (fondo) -->
  <div
    class="absolute inset-0 opacity-[0.04] pointer-events-none"
    aria-hidden="true"
  >
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="pasta-pattern" x="0" y="0" width="120" height="120" patternUnits="userSpaceOnUse">
          <!-- Tagliatelle líneas onduladas -->
          <path d="M 10 30 Q 30 20, 50 30 T 90 30" stroke="#000" stroke-width="1.5" fill="none" />
          <path d="M 10 40 Q 30 30, 50 40 T 90 40" stroke="#000" stroke-width="1.5" fill="none" />
          <!-- Ravioles cuadrados -->
          <rect x="20" y="65" width="18" height="18" rx="2" stroke="#000" stroke-width="1.2" fill="none" />
          <circle cx="29" cy="74" r="1.5" fill="#000" />
          <!-- Espirales -->
          <circle cx="75" cy="80" r="8" stroke="#000" stroke-width="1.2" fill="none" />
          <circle cx="75" cy="80" r="4" stroke="#000" stroke-width="1.2" fill="none" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#pasta-pattern)" />
    </svg>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <!-- Texto -->
      <div class="lg:col-span-7 order-2 lg:order-1">
        <div class="opacity-0 animate-fade-up" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 rounded-full bg-ebg-naranja/10 text-ebg-naranja-oscuro px-3 py-1 font-display text-xs font-semibold tracking-widest uppercase">
            <span class="h-1.5 w-1.5 rounded-full bg-ebg-naranja animate-pulse"></span>
            Villa Ballester · desde hace +30 años
          </span>
        </div>

        <h1 class="mt-6 font-display font-bold text-ebg-negro leading-[0.95] tracking-tight opacity-0 animate-fade-up" style="animation-delay: 0.25s;">
          <span class="block text-4xl sm:text-5xl md:text-6xl lg:text-7xl">Tradición de barrio,</span>
          <span class="block text-4xl sm:text-5xl md:text-6xl lg:text-7xl mt-1 relative inline-block">
            mirada de
            <span class="relative inline-block">
              <span class="relative z-10 text-ebg-naranja italic">futuro</span>
              <!-- Trazo gestual naranja debajo de "futuro" -->
              <svg
                class="absolute -bottom-2 left-0 w-full h-3 opacity-0 animate-draw-stroke"
                style="animation-delay: 1.1s;"
                viewBox="0 0 200 12"
                preserveAspectRatio="none"
                aria-hidden="true"
              >
                <path
                  d="M 4 8 Q 50 2, 100 6 T 196 4"
                  stroke="#FF7D0E"
                  stroke-width="4"
                  fill="none"
                  stroke-linecap="round"
                  stroke-dasharray="1000"
                  stroke-dashoffset="0"
                />
              </svg>
            </span>
            .
          </span>
        </h1>

        <p class="mt-6 max-w-xl font-body text-base md:text-lg text-ebg-negro/75 leading-relaxed opacity-0 animate-fade-up" style="animation-delay: 0.5s;">
          Una fábrica de <strong class="font-semibold">pastas frescas artesanales</strong> en Villa Ballester. Combinamos el oficio de siempre con tecnología, más sabores y una experiencia de compra pensada para vos.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4 opacity-0 animate-fade-up" style="animation-delay: 0.7s;">
          <a
            href="https://www.pedidosporwhatsapp.com.ar/elbuengustopastas"
            target="_blank"
            rel="noopener"
            class="group inline-flex items-center gap-3 rounded-full bg-ebg-naranja hover:bg-ebg-naranja-oscuro text-ebg-crema px-7 py-4 font-display font-bold text-base md:text-lg transition-all duration-300 shadow-lg shadow-ebg-naranja/30 hover:shadow-xl hover:shadow-ebg-naranja/40 hover:-translate-y-0.5"
          >
            <span>Hacé tu pedido</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </a>

          <a
            href="#productos"
            class="inline-flex items-center gap-2 font-display text-base text-ebg-negro hover:text-ebg-naranja transition-colors group"
          >
            <span class="underline-offset-4 decoration-2 group-hover:underline">Ver nuestros productos</span>
          </a>
        </div>

        <!-- Mini stats -->
        <div class="mt-12 grid grid-cols-3 gap-6 max-w-md opacity-0 animate-fade-up" style="animation-delay: 0.9s;">
          <div>
            <p class="font-display font-bold text-3xl md:text-4xl text-ebg-naranja">+30</p>
            <p class="font-body text-xs text-ebg-negro/70 mt-1 leading-tight">sabores de rellenos</p>
          </div>
          <div>
            <p class="font-display font-bold text-3xl md:text-4xl text-ebg-naranja">+30</p>
            <p class="font-body text-xs text-ebg-negro/70 mt-1 leading-tight">años en el barrio</p>
          </div>
          <div>
            <p class="font-display font-bold text-3xl md:text-4xl text-ebg-naranja">300</p>
            <p class="font-body text-xs text-ebg-negro/70 mt-1 leading-tight">m² de planta y local</p>
          </div>
        </div>
      </div>

      <!-- Imagen / KV -->
      <div class="lg:col-span-5 order-1 lg:order-2 relative">
        <div class="relative opacity-0 animate-fade-in" style="animation-delay: 0.3s;">
          <!-- Glow naranja detrás -->
          <div class="absolute -inset-6 bg-ebg-naranja/20 rounded-full blur-3xl"></div>

          <!-- Carrusel automático de fotos -->
          <div
            id="hero-carrusel"
            class="relative aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl shadow-ebg-negro/20"
          >
            <img src="/img/hero-carrusel/1.webp" alt="Pastas artesanales El Buen Gusto" class="hero-slide absolute inset-0 w-full h-full object-cover opacity-100 transition-opacity duration-700 ease-in-out" loading="eager" />
            <img src="/img/hero-carrusel/2.webp" alt="" class="hero-slide absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700 ease-in-out" loading="lazy" />
            <img src="/img/hero-carrusel/3.webp" alt="" class="hero-slide absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700 ease-in-out" loading="lazy" />
            <img src="/img/hero-carrusel/4.webp" alt="" class="hero-slide absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700 ease-in-out" loading="lazy" />
            <img src="/img/hero-carrusel/5.webp" alt="" class="hero-slide absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700 ease-in-out" loading="lazy" />
          </div>

          <!-- Badge flotante: "Pastas frescas" -->
          <div
            class="absolute -left-4 md:-left-8 top-8 bg-ebg-negro text-ebg-crema rounded-2xl px-4 py-3 shadow-xl rotate-[-6deg] animate-float-slow"
          >
            <p class="font-display text-xs uppercase tracking-widest text-ebg-naranja">Hoy</p>
            <p class="font-display font-bold text-sm leading-tight">Pastas<br/>frescas</p>
          </div>

          <!-- Badge flotante: sello redondo -->
          <div
            class="absolute -right-4 md:-right-6 bottom-12 bg-ebg-crema border-2 border-ebg-naranja rounded-full h-24 w-24 md:h-28 md:w-28 flex items-center justify-center shadow-xl rotate-[8deg] animate-float-slow"
            style="animation-delay: 1.5s;"
          >
            <div class="text-center">
              <p class="font-display font-bold text-ebg-naranja text-2xl md:text-3xl leading-none">100%</p>
              <p class="font-display text-[10px] uppercase tracking-wider text-ebg-negro mt-1">artesanal</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Carrusel automático del Hero — rota cada 1.5s
    const slides = document.querySelectorAll('#hero-carrusel .hero-slide');
    if (slides.length > 1) {
      let idx = 0;
      setInterval(() => {
        slides[idx].classList.replace('opacity-100', 'opacity-0');
        idx = (idx + 1) % slides.length;
        slides[idx].classList.replace('opacity-0', 'opacity-100');
      }, 1500);
    }
  </script>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in" style="animation-delay: 1.5s;">
    <div class="flex flex-col items-center gap-2 text-ebg-negro/40">
      <span class="font-display text-[10px] uppercase tracking-widest">Seguí scrolleando</span>
      <svg class="h-4 w-4 animate-bounce" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 3a.75.75 0 01.75.75v10.638l3.96-4.158a.75.75 0 111.08 1.04l-5.25 5.5a.75.75 0 01-1.08 0l-5.25-5.5a.75.75 0 111.08-1.04l3.96 4.158V3.75A.75.75 0 0110 3z" clip-rule="evenodd" />
      </svg>
    </div>
  </div>
</section>
