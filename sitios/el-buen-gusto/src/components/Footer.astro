---
// Footer — El Buen Gusto Pastas
---

<footer class="bg-ebg-negro text-ebg-crema">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <!-- Brand + claim -->
      <div class="md:col-span-5">
        <img
          src="/img/logo/logo-color.png"
          alt="El Buen Gusto Pastas"
          class="h-40 md:h-52 w-auto"
          width="208"
          height="208"
        />
        <p class="mt-6 font-display text-2xl md:text-3xl leading-tight max-w-md">
          Tradición de barrio, <span class="text-ebg-naranja">mirada de futuro</span>.
        </p>
        <p class="mt-3 font-body text-sm text-ebg-crema/70 max-w-md">
          Fábrica de pastas frescas artesanales en Villa Ballester.
        </p>
      </div>

      <!-- Visitanos -->
      <div class="md:col-span-3">
        <h3 class="font-display text-xs uppercase tracking-widest text-ebg-naranja mb-4">Visitanos</h3>
        <address class="not-italic font-body text-sm space-y-1.5 text-ebg-crema/85">
          <p>Pueyrredón 2631</p>
          <p>Villa Ballester, BA</p>
        </address>
        <h4 class="font-display text-xs uppercase tracking-widest text-ebg-naranja mt-6 mb-3">Horarios</h4>
        <ul class="font-body text-sm space-y-1 text-ebg-crema/85">
          <li>Mar a sáb · 8:30 a 20:30</li>
          <li>Dom · 8:30 a 13:30</li>
        </ul>
      </div>

      <!-- Contacto / Redes -->
      <div class="md:col-span-4">
        <h3 class="font-display text-xs uppercase tracking-widest text-ebg-naranja mb-4">Contacto</h3>
        <ul class="font-body text-sm space-y-2.5">
          <li>
            <a
              href="https://wa.me/5491132642454"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 hover:text-ebg-naranja transition-colors"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
