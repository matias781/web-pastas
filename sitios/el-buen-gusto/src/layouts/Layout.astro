---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'El Buen Gusto Pastas — Fábrica de pastas frescas artesanales en Villa Ballester. Tradición de barrio, mirada de futuro.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#FF7D0E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_AR" />

    <title>{title}</title>

    <!-- Fuentes — DM Sans (manual de marca) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400;1,9..40,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-ebg-crema text-ebg-negro font-body antialiased">
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  /* Selección de texto en naranja de marca */
  ::selection {
    background-color: #FF7D0E;
    color: #FFF5EE;
  }

  /* Scroll-reveal: cuando un elemento entra al viewport */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Logo del menú: respiración sutil continua + giro al hover */
  .ebg-logo-anim {
    animation: ebgLogoBreath 4s ease-in-out infinite;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-origin: center;
    will-change: transform;
  }
  .ebg-logo-wrap:hover .ebg-logo-anim {
    transform: rotate(360deg) scale(1.08);
  }
  @keyframes ebgLogoBreath {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); }
  }

  /* Reveal de entrada del logo al cargar */
  .ebg-logo-wrap .ebg-logo-anim {
    animation: ebgLogoEnter 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) 0s 1 forwards,
               ebgLogoBreath 4s ease-in-out 0.9s infinite;
  }
  @keyframes ebgLogoEnter {
    from { opacity: 0; transform: scale(0.4) rotate(-90deg); }
    to { opacity: 1; transform: scale(1) rotate(0deg); }
  }
</style>

<script>
  // Scroll-reveal observer
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
